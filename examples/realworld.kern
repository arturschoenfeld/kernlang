## Example program for lexer stress testing

use math
use io

pub struct Vec3 {
    x flt32
    y flt32
    z flt32
}

pub fn vec_add(a Vec3, b Vec3) -> Vec3 {
    var result Vec3

    result.x = a.x + b.x
    result.y = a.y + b.y
    result.z = a.z + b.z

    return result
}

pub fn vec_dot(a Vec3, b Vec3) -> flt32 {
    return a.x * b.x +
           a.y * b.y +
           a.z * b.z
}

pub fn factorial(n u32) -> u64 {
    if n eq 0 {
        return 1
    }

    var result u64 = 1
    var i u32 = 1

    while i lte n {
        result = result * i
        i = i + 1
    }

    return result
}

pub fn fib(n u32) -> u64 {
    if n lte 1 {
        return n
    }

    var a u64 = 0
    var b u64 = 1
    var i u32 = 2

    while i lte n {
        var next u64 = a + b
        a = b
        b = next
        i = i + 1
    }

    return b
}

