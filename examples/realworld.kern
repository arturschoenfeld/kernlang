## operators

var a = 10
var b = 20

var sum = a + b
var diff = a - b
var prod = a * b
var quot = a / b
var rem  = a % b

var range1 = 0 .. 10
var range2 = 0 ..= 10

## comparisons using keywords

if a gt b {
    io.print("a greater")
} else {
    io.print("b greater")
}

if a eq b {
    io.print("equal")
}

